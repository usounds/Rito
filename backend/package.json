{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "target": "esnext",
  "scripts": {
    "start": "pnpm exec tsx src/index.ts",
    "dev": "pnpm exec tsx --watch src/index.ts",
    "update": "pnpm up -L && pnpm install",
    "prisma:apply": "pnpm prisma migrate dev --name init",
    "prisma:generate": "pnpm prisma generate",
    "docker:build": "docker build -t rito-backend:latest .",
    "docker:run": "docker run -it --rm --name rito-backend --env-file .env rito-backend:latest",
    "docker:push": "docker buildx build --platform linux/amd64 -t ghcr.io/usounds/rito-backend:latest . --push",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check-missing": "tsx src/scripts/verify_posts_and_likes.ts",
    "backup-missing": "tsx src/scripts/backup_missing_to_csv.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "packageManager": "pnpm@11.5.0",
  "dependencies": {
    "@atcute/bluesky": "^4.0.10",
    "@atcute/client": "^5.1.0",
    "@atcute/lexicons": "^2.0.1",
    "@atcute/tid": "^1.1.2",
    "@atproto/api": "^0.20.16",
    "@atproto/jwk-jose": "^0.2.1",
    "@atproto/oauth-client-node": "^0.4.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@skyware/jetstream": "^0.2.5",
    "dotenv": "^17.4.2",
    "openai": "^6.44.0",
    "p-limit": "^7.3.0",
    "p-queue": "^9.3.0",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.22.4",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.4",
    "@types/pg": "8.20.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.9",
    "prisma": "^7.8.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
