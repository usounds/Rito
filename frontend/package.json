{
  "name": "rito",
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.5.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack -p 4600",
    "update": "pnpm dlx npm-check-updates -u && pnpm install && pnpm update",
    "build": "pnpm run prisma:generate && next build --webpack",
    "prisma:copy": " cp ../backend/prisma/schema.prisma ./prisma/schema.prisma",
    "prisma:generate": "pnpm exec prisma generate --schema=./prisma/schema.prisma",
    "start": "next start",
    "lex-gen": "npx lex-cli generate -c ./lex.config.js",
    "docker:push": "dotenv -e .env -- sh -c 'docker buildx build --platform linux/amd64 -t ghcr.io/usounds/rito-frontend:latest --build-arg DATABASE_URL=\"$DATABASE_URL\" --build-arg NEXT_PUBLIC_URL=\"https://rito.blue\" . --push' && git push",
    "update:blocklist": "curl -s https://raw.githubusercontent.com/StevenBlack/hosts/master/alternates/fakenews-gambling-porn-only/hosts | grep -v '^#' | awk '{print $2}' | grep -v '^$' | jq -R -s 'split(\"\\n\") | map(select(. != \"\"))' > src/data/blocklist.json",
    "update:publicsuffix": "curl -s https://publicsuffix.org/list/public_suffix_list.dat | grep -vE '(^//|^$)' | grep -v '^$' | jq -R -s 'split(\"\\n\") | map(select(. != \"\"))' > src/data/publicSuffixList.json",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e:db:start": "sh scripts/e2e-db.sh start",
    "test:e2e:db:wait": "sh scripts/e2e-db.sh wait",
    "test:e2e:db:stop": "sh scripts/e2e-db.sh stop",
    "test:e2e:db:reset": "sh scripts/e2e-db.sh reset",
    "test:e2e:setup": "DATABASE_URL=\"postgresql://postgres:test@localhost:5433/rito_test\" sh -c 'pnpm exec prisma db push && pnpm exec tsx tests/e2e/setup/seed.ts'",
    "test:e2e:prepare": "pnpm run test:e2e:db:start && pnpm run test:e2e:setup",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@atcute/atproto": "^4.0.0",
    "@atcute/bluesky": "^4.0.1",
    "@atcute/bluesky-richtext-builder": "^4.0.0",
    "@atcute/client": "^5.0.0",
    "@atcute/lexicons": "^2.0.0",
    "@atcute/tid": "^1.1.2",
    "@atpassport/client": "^0.1.33",
    "@atproto/api": "^0.19.18",
    "@atproto/jwk-jose": "^0.1.11",
    "@atproto/oauth-client-node": "^0.3.17",
    "@mantine/core": "^9.2.1",
    "@mantine/form": "^9.2.1",
    "@mantine/hooks": "^9.2.1",
    "@mantine/notifications": "^9.2.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tabler/icons-react": "^3.44.0",
    "base64url": "^3.0.1",
    "did-jwt": "^8.0.18",
    "did-resolver": "^5.0.1",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "next-intl": "^4.12.0",
    "nextjs-toploader": "^3.9.17",
    "open-graph-scraper": "^6.11.0",
    "pg": "^8.20.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "sass": "^1.99.0",
    "tinyld": "^1.3.4",
    "web-did-resolver": "^2.0.32",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@atcute/lex-cli": "^3.0.1",
    "@next/eslint-plugin-next": "^16.2.6",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.8.0",
    "@types/pg": "8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "4.1.6",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.4.0",
    "eslint-config-next": "16.2.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.14",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  },
  "engines": {
    "pnpm": ">=10.0.0"
  }
}
